{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ShipSmart: Debug App",
            "type": "chrome",
            "request": "launch",
            "preLaunchTask": "start: shipsmart",
            "url": "http://localhost:4200/",
            "webRoot": "${workspaceFolder}/shipsmart",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:///./*": "${webRoot}/*",
                "webpack:///*": "${webRoot}/*",
                "/./*": "${webRoot}/*",
                "/src/*": "${webRoot}/src/*",
                "/*": "${webRoot}/*"
            },
            "skipFiles": [
                "${workspaceFolder}/shipsmart/node_modules/**/*.js"
            ]
        }
    ]
}